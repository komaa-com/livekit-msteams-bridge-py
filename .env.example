# --- required ---
WORKER_SHARED_SECRET=shared-secret-from-standin-pairing
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...

# --- agent dispatch ---
# EXPLICIT dispatch (LiveKit's recommended model). Must equal the exact agent_name
# your worker registers with (WorkerOptions(agent_name=...)).
# WARNING: a worker that registers a name is ONLY reachable by explicit dispatch. If
# your worker sets agent_name but you leave this unset, the bridge falls back to
# automatic dispatch and your agent will NEVER join - the single most common mistake.
# Leave unset ONLY if your worker also registers with no name (automatic dispatch,
# prototype-only).
LIVEKIT_AGENT_NAME=standin-voice-agent
#LIVEKIT_ROOM_PREFIX=msteams-
#LIVEKIT_DELETE_ROOM_ON_END=true

# --- avatar video on the Teams tile (opt-in) ---
# Relay an avatar agent's video track onto the caller's Teams tile.
# off (default) = StandIn's built-in animated avatar; auto = the agent participant;
# or a specific participant identity. FPS is the relay send rate.
#LIVEKIT_TILE_VIDEO=auto
#LIVEKIT_TILE_VIDEO_FPS=15

# --- listener ---
#PORT=8080
#BIND=0.0.0.0
# Native TLS (wss). Leave unset when a tunnel/ingress terminates TLS for you.
#TLS_CERT_PATH=/path/cert.pem
#TLS_KEY_PATH=/path/key.pem

# --- call governor ---
#MAX_CALL_MINUTES=10
#GOODBYE_TEXT=I'm sorry, we've reached the time limit for this call. Thank you for calling, goodbye!
#GOODBYE_GRACE_MS=8000

# --- hardening ---
#HMAC_FRESHNESS_MS=60000
#MAX_CONNECTIONS=64
#MAX_CONNECTIONS_PER_IP=
#PRE_START_TIMEOUT_MS=10000
#WORKER_IDLE_TIMEOUT_MS=90000
#TRUST_PROXY_XFF=false

# --- logging ---
#LOG_LEVEL=info
